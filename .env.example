# === AI Strategic Partner — Environment Configuration ===

# OpenAI
OPENAI_API_KEY=your_key_here
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_STRONG=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Redis (PICP Bus)
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_PERSIST_DIR=./data/embedded

# Logging
LOG_LEVEL=INFO

# Trust Pillar Weights (Eq. 3.28)
TRUST_WEIGHT_EVIDENCE=0.4
TRUST_WEIGHT_COHERENCE=0.4
TRUST_WEIGHT_AGREEMENT=0.2

# Hybrid Search (Eq. 3.17)
HYBRID_SEARCH_ALPHA=0.7

# Monte Carlo
MONTE_CARLO_SIMULATIONS=10000

# PICP
PICP_LOCK_TTL_MS=5000
PICP_LOCK_RETRY_DELAY_MS=200
PICP_LOCK_MAX_RETRIES=10
